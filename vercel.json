{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "api/internal/facebook-scrape.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/internal/facebook-scrape",
      "dest": "api/internal/facebook-scrape.js"
    },
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ],
  "env": {
    "PYTHONPATH": "/var/task"
  }
}
