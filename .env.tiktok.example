# TikTok Auto-Refresh Credentials
# Copy ini ke .env.tiktok dan isi valuenya
# JANGAN COMMIT FILE INI KE GIT!

# TikTok Login Credentials (akun yang punya akses ke msToken)
TIKTOK_USERNAME=your_tiktok_username_or_email
TIKTOK_PASSWORD=your_tiktok_password

# Vercel API Credentials (untuk update env var otomatis)
# Dapatkan di: https://vercel.com/account/tokens
VERCEL_TOKEN=vercel_personal_access_token

# Project ID di Vercel (dari URL: vercel.com/ORG/PROJECT)
VERCEL_PROJECT_ID=prj_xxxxxxxxxxxxxxxx

# Optional: Team/Org ID (kalau project di team)
# VERCEL_ORG_ID=team_xxxxxxxxxxxxxxxx

# Environment target: production / preview
VERCEL_ENV_TARGET=production