# Salin file ini ke .env dan isi nilainya
APP_NAME=JAYAPONA
APP_ENV=production

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/jayapona?retryWrites=true&w=majority
MONGO_DB=jayapona

# JWT — ganti dengan random string panjang
JWT_SECRET=ganti-ini-random-string-minimal-32-karakter
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# CORS
CORS_ORIGINS=*
