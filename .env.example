# Salin file ini ke .env dan isi nilainya
APP_NAME=JAYAPONA
APP_ENV=production

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://USERNAME:***@cluster.mongodb.net/jayapona?retryWrites=true&w=majority
MONGO_DB=jayapona

# JWT — ganti dengan random string panjang
JWT_SECRET=ganti-ini-random-string-minimal-32-karakter
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# CORS
CORS_ORIGINS=*

# Cron Secret — untuk verifikasi Vercel Cron job (generate random string)
CRON_SECRET=ganti-ini-random-string-cron-secret

# TikTok Scraper — ms_token dari cookie TikTok (wajib untuk auto-sync)
TIKTOK_MS_TOKEN=your_tiktok_ms_token_here
